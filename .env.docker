# ===========================
# MailTrendz Docker Environment
# ===========================

# ====== SISTEMA ======
NODE_ENV=production
SERVICE_MODE=full
LOG_LEVEL=info

# ====== PORTAS ======
BACKEND_PORT=8000
PYTHON_AI_PORT=5000

# ====== MONGODB ======
MONGO_ROOT_PASSWORD=your-secure-mongo-password-here
MONGODB_URL=mongodb://admin:your-secure-mongo-password-here@mongodb:27017/mailtrendz?authSource=admin

# ====== JWT SECRETS ======
# ⚠️ ALTERAR EM PRODUÇÃO
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars

# ====== OPENROUTER API ======
# Obter em: https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ====== FRONTEND ======
FRONTEND_URL=http://localhost:3000

# ====== FEATURES ======
RUN_MIGRATION=false
VALIDATE_SYSTEM=true

# ====== EMAIL (Opcional) ======
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ====== MONITORING ======
GRAFANA_PASSWORD=admin123

# ====== REDIS (Opcional) ======
REDIS_URL=redis://redis:6379

# ====== DESENVOLVIMENTO ======
# Descomente para desenvolvimento local
# MONGODB_URL=mongodb://localhost:27017/mailtrendz
# PYTHON_AI_SERVICE_URL=http://localhost:5000
# NODE_ENV=development