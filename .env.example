# ✅ MAILTRENDZ BACKEND - CONFIGURAÇÕES ESSENCIAIS

# ================================
# APLICAÇÃO
# ================================
NODE_ENV=production
PORT=8000
API_VERSION=v1

# ================================
# MONGODB
# ================================
MONGODB_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/mailtrendz
MONGODB_DATABASE=mailtrendz

# ================================
# AUTENTICAÇÃO JWT
# ================================
JWT_SECRET=seu_jwt_secret_super_secreto_aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=seu_refresh_token_secret_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# PYTHON AI SERVICE
# ================================
PYTHON_AI_SERVICE_URL=https://python-ai-service.railway.app
PYTHON_AI_TIMEOUT=45000

# ================================
# OPENROUTER (PARA PYTHON AI)
# ================================
OPENROUTER_API_KEY=sk-or-v1-sua_chave_openrouter_aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ================================
# URLS FRONTEND
# ================================
FRONTEND_URL=https://seu-frontend.railway.app
BACKEND_URL=https://seu-backend.railway.app

# ================================
# CORS
# ================================
ALLOWED_ORIGINS=https://seu-frontend.railway.app