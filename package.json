{
  "name": "mailtrendz-backend",
  "version": "1.0.0",
  "description": "Backend for MailTrendz - AI-powered email generation platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "validate": "ts-node scripts/validate-setup.ts",
    "db:reset": "ts-node scripts/reset-database.ts",
    "db:seed": "ts-node scripts/seed-database.ts",
    "logs:clear": "rm -rf logs/*.log || del /q logs\\*.log",
    "docker:build": "docker build -t mailtrendz-backend .",
    "docker:run": "docker run -p 8000:8000 mailtrendz-backend",
    "docker:dev": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "setup": "npm install && npm run validate && echo '\n🎉 Setup completed! Run npm run dev to start'"
  },
  "keywords": ["email", "ai", "marketing", "automation", "openrouter", "mongodb"],
  "author": "Gabriel",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@types/bcryptjs": "^2.4.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.15",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/cookie-parser": "^1.4.6",
    "@types/express-validator": "^3.0.0",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.7",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
