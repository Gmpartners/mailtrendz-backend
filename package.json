{
  "name": "mailtrendz-backend",
  "version": "2.0.0",
  "description": "MailTrendz Backend API with Python AI Integration",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc --noEmitOnError false --skipLibCheck true",
    "start": "node dist/server.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "backend",
    "api",
    "python",
    "ai-service",
    "email-marketing"
  ],
  "author": "Gabriel",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@types/bcryptjs": "^2.4.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.15",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/cookie-parser": "^1.4.6",
    "@types/express-validator": "^3.0.0",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1"
  }
}