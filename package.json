    "@types/cheerio": "^0.22.35",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/express-validator": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.15.4",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.1.0",
