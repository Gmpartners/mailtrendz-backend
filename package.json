  "description": "MailTrendz Backend API with Integrated AI Service (OpenRouter)",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
