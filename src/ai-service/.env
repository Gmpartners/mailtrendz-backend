# ✅ PYTHON AI SERVICE - CONFIGURAÇÕES ESPECÍFICAS
# MailTrendz Python AI Service

# ================================
# SERVIÇO
# ================================
PORT=5000
HOST=0.0.0.0
DEBUG=true
RELOAD=true
LOG_LEVEL=info

# ================================
# OPENROUTER API (IA)
# ================================
OPENROUTER_API_KEY=sk-or-v1-sua_chave_openrouter_aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ================================
# MODELOS DE IA
# ================================
AI_PRIMARY_MODEL=anthropic/claude-3.5-sonnet
AI_FALLBACK_MODELS=anthropic/claude-3-sonnet-20240229,anthropic/claude-3-haiku-20240307
AI_MAX_TOKENS=2500
AI_TEMPERATURE=0.7

# ================================
# MONGODB
# ================================
MONGODB_URL=mongodb://localhost:27017/mailtrendz
MONGODB_DATABASE=mailtrendz

# ================================
# CACHE E PERFORMANCE
# ================================
AI_CACHE_ENABLED=true
AI_CACHE_TTL=300
PERFORMANCE_MONITORING=true

# ================================
# LOGS
# ================================
LOG_FILE=logs/ai-service.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# ================================
# DESENVOLVIMENTO
# ================================
ENABLE_DOCS=true
ENABLE_REDOC=true
CORS_ORIGINS=*