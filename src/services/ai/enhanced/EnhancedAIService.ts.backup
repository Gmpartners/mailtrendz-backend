import { EmailContent, ProjectContext, AIChatResponse } from '../../../types/ai.types'
import { EnhancedEmailContent, SmartEmailRequest, EnhancedChatResponse, PromptAnalysis, UserHistory } from '../../../types/enhanced-ai.types'
import { AI_MODELS, AI_CONFIG } from '../../../utils/constants'
import { logger } from '../../../utils/logger'
import EmailHTMLValidator from '../../../utils/htmlValidator'

interface OpenRouterConfig {
  apiKey: string
  baseURL: string
  defaultModel: string
  fallbackModels: string[]
}

interface OpenRouterResponse {
  choices?: Array<{
    message: {
      content: string
    }
  }>
  usage?: {
    total_tokens?: number
    prompt_tokens?: number
    completion_tokens?: number
  }
  error?: {
    message: string
    type: string
    code?: string
  }
}

class EnhancedAIService {
  private config: OpenRouterConfig

  constructor() {
    const fallbackModels = Array.isArray(AI_MODELS?.FALLBACKS) 
      ? [...AI_MODELS.FALLBACKS] 
      : [
          'anthropic/claude-3-sonnet-20240229',
          'anthropic/claude-3-haiku-20240307',
          'openai/gpt-4-turbo',
          'openai/gpt-3.5-turbo'
        ]

    this.config = {
      apiKey: process.env.OPENROUTER_API_KEY!,
      baseURL: process.env.OPENROUTER_BASE_URL || 'https://openrouter.ai/api/v1',
      defaultModel: 'anthropic/claude-3-sonnet-20240229',
      fallbackModels
    }

    this.validateConfiguration()
  }

  private validateConfiguration(): void {
    if (!this.config.apiKey) {
      throw new Error('OPENROUTER_API_KEY é obrigatória nas variáveis de ambiente')
    }
  }

  // ✅ MELHORADO: Validação usando HTMLValidator
  private validateAndFormatHTML(html: string, context?: string): { 
    html: string, 
    qualityScore: number, 
    issues: string[], 
    fixes: string[] 
  } {
    try {
      console.log('🔍 [HTML VALIDATOR] Validando HTML...', {
        length: html?.length || 0,
        context: context || 'unknown'
      })

      const validation = EmailHTMLValidator.validateAndSanitize(html)
      const qualityScore = EmailHTMLValidator.calculateQualityScore(validation.sanitizedHTML)
      
      console.log('✅ [HTML VALIDATOR] HTML validado:', {
        isValid: validation.isValid,
        qualityScore: qualityScore.score,
        issuesCount: validation.issues.length,
        fixesCount: validation.fixes.length
      })

      // Log de issues para debug
      if (validation.issues.length > 0) {
        console.log('⚠️ [HTML VALIDATOR] Issues encontradas:', validation.issues)
      }

      if (validation.fixes.length > 0) {
        console.log('🔧 [HTML VALIDATOR] Correções aplicadas:', validation.fixes)
      }

      return {
        html: validation.sanitizedHTML,
        qualityScore: qualityScore.score,
        issues: validation.issues,
        fixes: validation.fixes
      }
    } catch (error: any) {
      console.error('❌ [HTML VALIDATOR] Erro na validação:', error.message)
      
      // Fallback seguro
      const fallbackHTML = EmailHTMLValidator.validateAndSanitize('').sanitizedHTML
      return {
        html: fallbackHTML,
        qualityScore: 30,
        issues: ['Erro na validação do HTML original'],
        fixes: ['HTML de fallback seguro gerado']
      }
    }
  }

  async generateSmartEmail(request: SmartEmailRequest): Promise<EnhancedEmailContent> {
    const startTime = Date.now()
    
    console.log('🚀 [ENHANCED AI] Gerando email inteligente:', {
      userId: request.projectContext.userId,
      promptLength: request.prompt.length,
      context: {
        type: request.projectContext.type,
        industry: request.projectContext.industry,
        tone: request.projectContext.tone
      }
    })
    
    try {
      const analysis = await this.analyzePrompt(request.prompt, request.projectContext, request.userHistory)
      const systemPrompt = this.buildSmartEmailPrompt(request.projectContext, analysis)
      const userPrompt = request.prompt

      const response = await this.callAI([
        { role: 'system', content: systemPrompt },
        { role: 'user', content: userPrompt }
      ])

      const emailContent = this.parseEmailResponse(response.content)
      const duration = Date.now() - startTime

      // ✅ VALIDAÇÃO COMPLETA COM NOVO SISTEMA
      console.log('🔍 [ENHANCED AI] Validando HTML gerado...')
      const htmlValidation = this.validateAndFormatHTML(emailContent.html, 'email-generation')
      const textContent = EmailHTMLValidator.extractPlainText(htmlValidation.html)

      // ✅ OTIMIZAÇÃO PARA CLIENTES DE EMAIL
      const optimizedHTML = EmailHTMLValidator.optimizeForEmailClients(htmlValidation.html)

      const enhancedContent: EnhancedEmailContent = {
        subject: emailContent.subject || 'Email Gerado por IA',
        previewText: emailContent.previewText || this.generatePreviewText(emailContent.subject || 'Confira nosso email'),
        html: optimizedHTML,
        text: textContent,
        css: this.generateSmartCSS(analysis),
        components: this.extractComponents(optimizedHTML),
        analysis,
        metadata: {
          version: '2.0.0-enhanced',
          generated: new Date(),
          model: response.model,
          tokens: response.usage?.total_tokens || 0,
          qualityScore: htmlValidation.qualityScore,
          compatibilityScore: htmlValidation.qualityScore > 70 ? 0.95 : 0.75,
          accessibilityScore: htmlValidation.qualityScore > 60 ? 0.92 : 0.70,
          estimatedRenderTime: htmlValidation.qualityScore > 80 ? 600 : 1000,
          supportedClients: htmlValidation.qualityScore > 70 
            ? ['Gmail', 'Outlook', 'Apple Mail', 'Yahoo', 'Thunderbird']
            : ['Gmail', 'Apple Mail', 'Yahoo'],
          enhancedFeatures: this.getEnhancedFeatures(analysis),
          processingTime: duration,
          isValidHTML: htmlValidation.issues.length === 0,
          htmlValidation: {
            issues: htmlValidation.issues,
            fixes: htmlValidation.fixes,
            qualityBreakdown: EmailHTMLValidator.calculateQualityScore(optimizedHTML).breakdown
          }
        }
      }
      
      console.log('✅ [ENHANCED AI] Email inteligente gerado com HTML validado:', {
        userId: request.projectContext.userId,
        duration: `${duration}ms`,
        htmlLength: optimizedHTML.length,
        qualityScore: htmlValidation.qualityScore,
        issuesResolved: htmlValidation.fixes.length,
        isValidHTML: htmlValidation.issues.length === 0
      })
      
      return enhancedContent
    } catch (error: any) {
      console.error('❌ [ENHANCED AI] Erro na geração inteligente:', error.message)
      throw new Error(`Falha na geração inteligente: ${error.message}`)
    }
  }

  // ✅ MELHORADO: Chat com validação robusta
  async smartChatWithAI(
    message: string,
    chatHistory: any[],
    projectContext: ProjectContext,
    userHistory?: UserHistory
  ): Promise<EnhancedChatResponse> {
    console.log('💬 [ENHANCED AI] Chat inteligente iniciado:', {
      messageLength: message.length,
      historyCount: chatHistory.length,
      hasProjectContent: projectContext.hasProjectContent
    })
    
    try {
      const analysis = await this.analyzePrompt(message, projectContext, userHistory)
      const systemPrompt = this.buildSmartChatPrompt(projectContext, analysis)
      
      const contextualSystemPrompt = this.enrichSystemPromptWithProject(systemPrompt, projectContext)
      
      const messages = [
        { role: 'system', content: contextualSystemPrompt },
        ...chatHistory.slice(-10).map(msg => ({
          role: msg.role || (msg.type === 'user' ? 'user' : 'assistant'),
          content: msg.content
        })),
        { role: 'user', content: message }
      ]

      const response = await this.callAI(messages)
      const shouldUpdateEmail = this.detectSmartIntent(message, analysis, projectContext)
      
      let enhancedContent = undefined
      
      // ✅ GERAÇÃO DE CONTEÚDO COM VALIDAÇÃO
      if (shouldUpdateEmail && projectContext.hasProjectContent) {
        console.log('🔧 [ENHANCED AI] Aplicando modificações no email...')
        const rawContent = await this.generateUpdatedEmailContent(
          message, 
          projectContext, 
          analysis
        )
        
        if (rawContent) {
          // ✅ VALIDAR CONTEÚDO ATUALIZADO
          const htmlValidation = this.validateAndFormatHTML(
            rawContent.html, 
            'content-modification'
          )
          
          const optimizedHTML = EmailHTMLValidator.optimizeForEmailClients(htmlValidation.html)
          const textContent = EmailHTMLValidator.extractPlainText(optimizedHTML)
          
          enhancedContent = {
            ...rawContent,
            html: optimizedHTML,
            text: textContent,
            metadata: {
              ...rawContent.metadata,
              isValidUpdate: htmlValidation.issues.length === 0,
              qualityScore: htmlValidation.qualityScore,
              validationIssues: htmlValidation.issues,
              appliedFixes: htmlValidation.fixes
            }
          }
          
          console.log('✅ [ENHANCED AI] Conteúdo modificado e validado:', {
            qualityScore: htmlValidation.qualityScore,
            issuesResolved: htmlValidation.fixes.length,
            hasValidHTML: htmlValidation.issues.length === 0
          })
        }
      }
      
      const enhancedResponse: EnhancedChatResponse = {
        response: response.content,
        shouldUpdateEmail,
        analysis,
        suggestions: this.generateSmartSuggestions(message, analysis, projectContext),
        enhancedContent,
        metadata: {
          model: response.model,
          tokens: response.usage?.total_tokens || 0,
          confidence: analysis.confidence,
          enhancedFeatures: [
            'smart-intent-detection', 
            'contextual-suggestions', 
            'project-context-awareness',
            'html-validation',
            shouldUpdateEmail ? 'content-modification' : 'conversational-response'
          ],
          processingTime: Date.now() - Date.now(),
          appliedModifications: shouldUpdateEmail,
          validationResults: enhancedContent?.metadata?.validationIssues || []
        }
      }
      
      console.log('✅ [ENHANCED AI] Chat inteligente processado:', {
        shouldUpdateEmail,
        confidence: Math.round(analysis.confidence * 100) + '%',
        hasEnhancedContent: !!enhancedResponse.enhancedContent,
        suggestions: enhancedResponse.suggestions.length,
        validationPassed: enhancedContent?.metadata?.isValidUpdate !== false
      })
      
      return enhancedResponse
    } catch (error: any) {
      console.error('❌ [ENHANCED AI] Erro no chat inteligente:', error.message)
      return this.createFallbackResponse(message, projectContext, error)
    }
  }

  // ✅ MELHORADO: Geração de conteúdo atualizado com validação
  private async generateUpdatedEmailContent(
    message: string, 
    projectContext: ProjectContext, 
    analysis: PromptAnalysis
  ): Promise<any> {
    try {
      console.log('🔧 [ENHANCED AI] Gerando conteúdo atualizado...')

      const modificationPrompt = this.buildModificationPrompt(message, projectContext, analysis)
      
      const response = await this.callAI([
        { role: 'system', content: modificationPrompt },
        { role: 'user', content: message }
      ])

      const updatedContent = this.parseEmailResponse(response.content)
      
      // ✅ VALIDAÇÃO: Verificar se conteúdo foi gerado
      const finalHTML = updatedContent.html || projectContext.currentEmailContent?.html
      const finalSubject = updatedContent.subject || projectContext.currentEmailContent?.subject
      const finalPreview = updatedContent.previewText || projectContext.currentEmailContent?.previewText
      
      if (!finalHTML) {
        throw new Error('Não foi possível gerar HTML atualizado')
      }
      
      // ✅ VALIDAÇÃO PRÉVIA ANTES DE RETORNAR
      const preValidation = this.validateAndFormatHTML(finalHTML, 'pre-update-validation')
      
      console.log('🔍 [ENHANCED AI] Conteúdo pré-validado:', {
        qualityScore: preValidation.qualityScore,
        hasIssues: preValidation.issues.length > 0,
        appliedFixes: preValidation.fixes.length
      })
      
      return {
        subject: finalSubject,
        previewText: finalPreview,
        html: preValidation.html, // Usar HTML já validado
        text: EmailHTMLValidator.extractPlainText(preValidation.html),
        metadata: {
          modifiedBy: message,
          modificationTimestamp: new Date(),
          analysisUsed: analysis,
          originalContent: projectContext.currentEmailContent,
          modificationType: analysis.intentions.map(i => i.action).join(', '),
          isValidUpdate: preValidation.issues.length === 0,
          preValidationScore: preValidation.qualityScore,
          preValidationIssues: preValidation.issues,
          preValidationFixes: preValidation.fixes
        }
      }
    } catch (error: any) {
      console.error('❌ [ENHANCED AI] Erro ao gerar conteúdo atualizado:', error.message)
      return undefined
    }
  }

  // ✅ MELHORADO: Prompt para modificações com foco em HTML válido
  private buildModificationPrompt(message: string, projectContext: ProjectContext, analysis: PromptAnalysis): string {
    return `Você é um especialista em modificação de emails HTML que deve aplicar mudanças específicas no conteúdo atual.

CONTEXTO DO PROJETO:
- Nome: ${projectContext.projectName}
- Tipo: ${projectContext.type}
- Indústria: ${projectContext.industry}
- Tom: ${projectContext.tone}

EMAIL ATUAL:
- Assunto: "${projectContext.currentEmailContent?.subject || 'Sem assunto'}"
- HTML Atual: ${projectContext.currentEmailContent?.html || 'Sem conteúdo'}

SOLICITAÇÃO DE MODIFICAÇÃO: "${message}"

ANÁLISE DA INTENÇÃO:
${analysis.intentions.map(i => `- ${i.action} em ${i.target} (confiança: ${Math.round(i.confidence * 100)}%)`).join('\n')}

INSTRUÇÕES CRÍTICAS PARA HTML VÁLIDO:
1. Analise EXATAMENTE o que o usuário pediu para modificar
2. Mantenha TODO o resto do email INALTERADO
3. Aplique APENAS as modificações solicitadas
4. SEMPRE use HTML válido e estruturado para emails
5. Use estrutura de TABELA para layout (não divs com flex/grid)
6. Aplique CSS INLINE para compatibilidade com clientes de email
7. Inclua atributos alt em imagens
8. Use cores válidas (hex, rgb ou nomes CSS)
9. Mantenha compatibilidade com Outlook, Gmail, Apple Mail
10. SEMPRE retorne um email HTML completo e funcional

ESTRUTURA OBRIGATÓRIA DO HTML:
- DOCTYPE html
- Tag html com lang="pt-BR"
- Head completo com meta tags
- CSS inline para todos os estilos
- Estrutura de tabela para layout
- Body com container principal

REGRAS DE MODIFICAÇÃO:
- Para cores: Use style="color: #hexcode; background-color: #hexcode;"
- Para textos: Altere diretamente o conteúdo preservando tags
- Para botões: Use tabela com CSS inline
- Para layout: Use table/tr/td estrutura
- Para responsividade: Inclua media queries no <style>

FORMATO OBRIGATÓRIO (JSON válido):
{
  "subject": "Assunto (modificado apenas se solicitado, senão manter original)",
  "previewText": "Preview (modificado apenas se solicitado, senão manter original)",
  "html": "HTML COMPLETO e VÁLIDO com as modificações aplicadas - DEVE ser um email funcional com estrutura completa",
  "text": "Versão texto das modificações aplicadas"
}

IMPORTANTE: 
- O HTML deve ser um email COMPLETO e FUNCIONAL
- Use APENAS estruturas compatíveis com clientes de email
- Teste mentalmente se funcionaria no Outlook
- NÃO retorne apenas fragmentos

Responda APENAS com o JSON válido, sem explicações ou comentários.`
  }

  // ✅ MELHORADO: Prompt para geração de emails com foco em qualidade
  private buildSmartEmailPrompt(context: ProjectContext, analysis: PromptAnalysis): string {
    return `Você é um especialista em email marketing com IA avançada, especializado em criar emails HTML responsivos, válidos e de alta conversão.

CONTEXTO DO PROJETO:
- Nome: ${context.projectName}
- Tipo: ${context.type}
- Indústria: ${context.industry}
- Público-alvo: ${context.targetAudience || 'Geral'}
- Tom: ${context.tone || 'Profissional'}

ANÁLISE DO PROMPT:
- Intenções detectadas: ${analysis.intentions.map(i => i.action).join(', ') || 'Criação de email'}
- Confiança: ${Math.round(analysis.confidence * 100)}%
- Tom solicitado: ${analysis.contentRequirements.tone}
- Foco: ${analysis.contentRequirements.focus.join(', ')}

INSTRUÇÕES PARA GERAÇÃO DE EMAIL HTML VÁLIDO:
1. Crie um email HTML COMPLETO e RESPONSIVO
2. Use ESTRUTURA DE TABELA para máxima compatibilidade
3. Inclua CSS INLINE para melhor renderização
4. Adicione meta tags essenciais para responsividade
5. Use cores e fontes que funcionam em todos os clientes
6. Inclua call-to-action (CTA) relevante e funcional
7. Garanta acessibilidade com alt text em imagens
8. Otimize para Gmail, Outlook, Apple Mail, Yahoo
9. Use HTML5 válido com DOCTYPE
10. Inclua CSS de reset para clientes de email

ESTRUTURA OBRIGATÓRIA:
- <!DOCTYPE html>
- <html lang="pt-BR">
- <head> com meta tags completas
- <style> com CSS de reset e responsivo
- <body> com estrutura de tabela
- Conteúdo otimizado para conversão
- Footer com informações básicas

COMPATIBILIDADE OBRIGATÓRIA:
- Outlook 2007-2019 (usar tabelas)
- Gmail (CSS inline necessário)
- Apple Mail (suporte completo)
- Yahoo Mail (CSS inline)
- Thunderbird (HTML padrão)

FORMATO OBRIGATÓRIO (JSON válido):
{
  "subject": "Assunto inteligente e otimizado (máximo 50 caracteres)",
  "previewText": "Preview complementar estratégico (máximo 90 caracteres)",
  "html": "HTML COMPLETO, VÁLIDO e RESPONSIVO do email com estrutura de tabela",
  "text": "Versão texto plano otimizada e legível"
}

IMPORTANTE: O HTML deve ser um email COMPLETO, FUNCIONAL e RESPONSIVO que funcionará em TODOS os principais clientes de email.

Responda APENAS com o JSON válido, sem explicações adicionais.`
  }

  // Outros métodos mantidos...
  private createFallbackResponse(
    message: string, 
    projectContext: ProjectContext, 
    originalError: Error
  ): EnhancedChatResponse {
    console.log('🔄 [ENHANCED AI] Criando resposta de fallback')

    let fallbackResponse = `Entendi sua mensagem sobre "${message.substring(0, 50)}${message.length > 50 ? '...' : ''}".`

    if (projectContext.hasProjectContent) {
      fallbackResponse += `\n\nVejo que você está trabalhando no projeto "${projectContext.projectName}". `
      
      if (message.toLowerCase().includes('cor')) {
        fallbackResponse += 'Para alterar cores, seja específico: "mude o botão para azul".'
      } else if (message.toLowerCase().includes('botão')) {
        fallbackResponse += 'Para modificar botões, especifique: cor, texto ou posição.'
      } else if (message.toLowerCase().includes('título')) {
        fallbackResponse += 'Para alterar títulos, me diga o novo texto desejado.'
      } else {
        fallbackResponse += 'Tente ser mais específico sobre a modificação desejada.'
      }
    }

    fallbackResponse += '\n\n⚠️ Houve um problema temporário. Tente novamente em alguns momentos.'

    return {
      response: fallbackResponse,
      shouldUpdateEmail: false,
      analysis: {
        intentions: [],
        visualRequirements: {},
        contentRequirements: {
          tone: 'professional',
          length: 'medium',
          focus: ['information'],
          urgency: 'medium',
          personalization: 'none'
        },
        confidence: 0.3,
        processingTime: 0,
        originalPrompt: message
      },
      suggestions: [
        'Tente reformular sua pergunta',
        'Seja mais específico',
        'Aguarde alguns momentos'
      ],
      enhancedContent: undefined,
      metadata: {
        model: 'fallback-service',
        tokens: 0,
        confidence: 0.3,
        enhancedFeatures: ['fallback-response'],
        processingTime: 100
      }
    }
  }

  // Métodos auxiliares mantidos...
  async analyzePrompt(prompt: string, projectContext?: ProjectContext, userHistory?: UserHistory): Promise<PromptAnalysis> {
    try {
      const intentions = this.extractIntentions(prompt, projectContext)
      const visualRequirements = this.extractVisualRequirements(prompt)
      const contentRequirements = this.extractContentRequirements(prompt, projectContext)
      const confidence = this.calculateConfidence(prompt, intentions, visualRequirements, projectContext)

      return {
        intentions,
        visualRequirements,
        contentRequirements,
        confidence,
        processingTime: 50,
        originalPrompt: prompt
      }
    } catch (error) {
      return {
        intentions: [],
        visualRequirements: {},
        contentRequirements: {
          tone: 'professional',
          length: 'medium',
          focus: ['information'],
          urgency: 'medium',
          personalization: 'none'
        },
        confidence: 0.5,
        processingTime: 0,
        originalPrompt: prompt
      }
    }
  }

  async healthCheck(): Promise<{ status: 'available' | 'unavailable', responseTime?: number }> {
    const startTime = Date.now()
    try {
      if (!this.config.apiKey) {
        return { status: 'unavailable', responseTime: 0 }
      }

      const controller = new AbortController()
      const timeoutId = setTimeout(() => controller.abort(), 5000)

      const testResponse = await fetch(`${this.config.baseURL}/models`, {
        headers: { 
          'Authorization': `Bearer ${this.config.apiKey}`,
          'Content-Type': 'application/json'
        },
        signal: controller.signal
      })

      clearTimeout(timeoutId)
      const responseTime = Date.now() - startTime
      
      if (testResponse.ok) {
        return { status: 'available', responseTime }
      } else {
        return { status: 'unavailable', responseTime }
      }
    } catch (error) {
      const responseTime = Date.now() - startTime
      return { status: 'unavailable', responseTime }
    }
  }

  private async callAI(messages: any[], modelOverride?: string): Promise<any> {
    let lastError: any
    const modelsToTry = modelOverride ? [modelOverride] : [this.config.defaultModel, ...this.config.fallbackModels]
    
    for (const model of modelsToTry) {
      try {
        const controller = new AbortController()
        const timeoutId = setTimeout(() => controller.abort(), 30000)

        const requestBody = {
          model,
          messages: messages.map(msg => ({
            role: msg.role,
            content: msg.content
          })),
          temperature: 0.7,
          max_tokens: 3000,
          stream: false
        }

        const response = await fetch(`${this.config.baseURL}/chat/completions`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${this.config.apiKey}`,
            'HTTP-Referer': process.env.FRONTEND_URL || 'https://mailtrendz-frontend.onrender.com',
            'X-Title': 'MailTrendz Enhanced AI'
          },
          body: JSON.stringify(requestBody),
          signal: controller.signal
        })

        clearTimeout(timeoutId)

        if (!response.ok) {
          const errorText = await response.text()
          let errorData: any = {}
          
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText }
          }
          
          throw new Error(`OpenRouter API error (${response.status}): ${errorData.error?.message || errorData.message || 'Unknown error'}`)
        }

        const data: OpenRouterResponse = await response.json()
        
        if (data.error) {
          throw new Error(`OpenRouter API error: ${data.error.message}`)
        }
        
        if (!data.choices || !data.choices[0] || !data.choices[0].message) {
          throw new Error('Resposta inválida da OpenRouter API')
        }
        
        return {
          content: data.choices[0].message.content,
          model,
          usage: data.usage || { total_tokens: 0 }
        }
      } catch (error: any) {
        lastError = error
        continue
      }
    }
    
    throw new Error(`Falha em todos os modelos AI: ${lastError?.message || 'Erro desconhecido'}`)
  }

  private parseEmailResponse(content: string): EmailContent {
    try {
      let cleanContent = content.trim()
      cleanContent = cleanContent.replace(/```json\n?|\n?```/g, '')
      
      const jsonMatch = cleanContent.match(/\{[\s\S]*\}/)
      if (jsonMatch) {
        cleanContent = jsonMatch[0]
      }
      
      const parsed = JSON.parse(cleanContent)
      
      return {
        subject: parsed.subject || 'Email Gerado por IA',
        previewText: parsed.previewText || 'Confira este email importante',
        html: parsed.html || EmailHTMLValidator.validateAndSanitize('').sanitizedHTML,
        text: parsed.text || 'Conteúdo gerado por IA'
      }
    } catch (error: any) {
      console.error('❌ Erro ao parsear resposta:', error.message)
      return {
        subject: 'Email Gerado por IA',
        previewText: 'Conteúdo criado automaticamente',
        html: EmailHTMLValidator.validateAndSanitize('Erro ao processar conteúdo').sanitizedHTML,
        text: 'Conteúdo gerado por IA'
      }
    }
  }

  // Métodos auxiliares simplificados... 
  private enrichSystemPromptWithProject(basePrompt: string, projectContext: ProjectContext): string {
    if (!projectContext.hasProjectContent || !projectContext.currentEmailContent) {
      return basePrompt
    }

    return basePrompt + `

CONTEXTO DO EMAIL ATUAL:
- Assunto: "${projectContext.currentEmailContent.subject || 'Não definido'}"
- Preview: "${projectContext.currentEmailContent.previewText || 'Não definido'}"
- Conteúdo HTML: ${projectContext.currentEmailContent.html ? 'Disponível para modificação' : 'Não disponível'}
- Prompt Original: "${projectContext.originalPrompt || 'Não disponível'}"

INSTRUÇÕES PARA MODIFICAÇÕES:
1. Quando solicitado, modifique o conteúdo atual específicamente
2. Mantenha a estrutura e funcionalidade do email
3. Use CSS inline para compatibilidade
4. Preserve elementos não mencionados na solicitação
5. Garanta que o HTML continue válido e responsivo
6. Use estrutura de tabela para layout
7. Mantenha compatibilidade com clientes de email`
  }

  private extractIntentions(prompt: string, projectContext?: ProjectContext): any[] {
    const intentions = []
    const promptLower = prompt.toLowerCase()

    const intentionPatterns = [
      { keywords: ['criar', 'gerar', 'fazer', 'novo'], action: 'create', target: 'content' },
      { keywords: ['mudar', 'alterar', 'modificar', 'trocar'], action: 'modify', target: 'existing' },
      { keywords: ['melhorar', 'otimizar'], action: 'improve', target: 'quality' },
      { keywords: ['cor', 'cores'], action: 'customize', target: 'colors' },
      { keywords: ['botão', 'cta'], action: 'modify', target: 'cta' },
      { keywords: ['título', 'assunto'], action: 'modify', target: 'title' },
      { keywords: ['texto', 'conteúdo'], action: 'modify', target: 'text' }
    ]

    intentionPatterns.forEach(pattern => {
      const hasKeyword = pattern.keywords.some(keyword => promptLower.includes(keyword))
      if (hasKeyword) {
        const confidence = projectContext?.hasProjectContent ? 0.9 : 0.7
        intentions.push({
          action: pattern.action,
          target: pattern.target,
          confidence,
          projectAware: !!projectContext?.hasProjectContent
        })
      }
    })

    return intentions
  }

  private extractVisualRequirements(prompt: string): any {
    const requirements: any = {}
    const promptLower = prompt.toLowerCase()

    if (promptLower.includes('cor') || promptLower.includes('color')) {
      requirements.colorScheme = {
        primary: this.extractColor(prompt) || '#3b82f6',
        detected: true,
        source: 'user_prompt'
      }
    }

    return requirements
  }

  private extractColor(prompt: string): string | null {
    const colorMap: { [key: string]: string } = {
      'azul': '#3b82f6',
      'vermelho': '#ef4444', 
      'verde': '#10b981',
      'amarelo': '#f59e0b',
      'roxo': '#8b5cf6',
      'preto': '#000000',
      'branco': '#ffffff',
      'cinza': '#6b7280'
    }

    const promptLower = prompt.toLowerCase()
    for (const [color, hex] of Object.entries(colorMap)) {
      if (promptLower.includes(color)) {
        return hex
      }
    }

    return null
  }

  private extractContentRequirements(prompt: string, context?: ProjectContext): any {
    const promptLower = prompt.toLowerCase()
    
    return {
      tone: context?.tone || 'professional',
      length: promptLower.includes('longo') ? 'long' : 'medium',
      focus: ['information'],
      urgency: promptLower.includes('urgente') ? 'high' : 'medium',
      personalization: 'basic'
    }
  }

  private calculateConfidence(prompt: string, intentions: any[], visualReqs: any, projectContext?: ProjectContext): number {
    let confidence = 0.3

    if (prompt.length > 20) confidence += 0.1
    if (intentions.length > 0) confidence += 0.2
    if (Object.keys(visualReqs).length > 0) confidence += 0.1

    if (projectContext?.hasProjectContent) {
      confidence += 0.2
      const hasModificationIntent = intentions.some(i => 
        ['modify', 'edit', 'improve', 'customize'].includes(i.action)
      )
      if (hasModificationIntent) confidence += 0.15
    }

    return Math.min(confidence, 1.0)
  }

  private detectSmartIntent(message: string, analysis: PromptAnalysis, projectContext?: ProjectContext): boolean {
    if (!projectContext?.hasProjectContent) return false
    
    const messageLower = message.toLowerCase()
    
    const modificationKeywords = [
      'mude', 'altere', 'modifique', 'troque', 'substitua',
      'edite', 'corrija', 'ajuste', 'melhore', 'otimize',
      'adicione', 'remova', 'inclua', 'retire', 'delete',
      'cor', 'botão', 'título', 'texto', 'assunto',
      'desconto', 'preço', 'valor', 'data', 'prazo',
      'fonte', 'tamanho', 'negrito', 'itálico',
      'imagem', 'logo', 'banner', 'background'
    ]
    
    const hasModificationKeywords = modificationKeywords.some(keyword =>
      messageLower.includes(keyword)
    )
    
    const modificationIntents = ['modify', 'edit', 'improve', 'customize', 'update']
    const hasModificationIntent = analysis.intentions.some(intent => 
      modificationIntents.includes(intent.action)
    )
    
    const modificationPatterns = [
      /deixe?\s+(mais|menos|muito)/i,
      /faça\s+o\s+\w+\s+(mais|menos)/i,
      /quero\s+(que|mudar|alterar)/i,
      /(pode|consegue)\s+(mudar|alterar|modificar)/i
    ]
    
    const hasModificationPattern = modificationPatterns.some(pattern =>
      pattern.test(message)
    )
    
    const shouldUpdate = hasModificationKeywords || hasModificationIntent || hasModificationPattern
    
    console.log('🔍 [ENHANCED AI] Análise de intenção:', {
      hasModificationKeywords,
      hasModificationIntent,
      hasModificationPattern,
      shouldUpdate,
      confidence: analysis.confidence
    })
    
    return shouldUpdate && analysis.confidence > 0.3
  }

  private generateSmartSuggestions(message: string, analysis: PromptAnalysis, projectContext?: ProjectContext): string[] {
    const suggestions = []
    
    if (analysis.confidence < 0.6) {
      suggestions.push('Seja mais específico sobre o que deseja modificar')
    }
    
    if (projectContext?.hasProjectContent) {
      suggestions.push('Posso aplicar mudanças automaticamente')
      suggestions.push('Ver prévia das modificações')
    }
    
    return suggestions.slice(0, 3)
  }

  private generatePreviewText(subject: string): string {
    return `${subject} - Confira os detalhes dentro!`
  }

  private generateSmartCSS(analysis: PromptAnalysis): string {
    return `.email-table { width: 100%; max-width: 600px; margin: 0 auto; font-family: Arial, sans-serif; }`
  }

  private extractComponents(html: string): any[] {
    return []
  }

  private calculateQualityScore(email: EmailContent, analysis: PromptAnalysis): number {
    let score = 0.5
    
    if (email.subject && email.subject.length > 5 && email.subject.length < 60) score += 0.2
    if (email.html && email.html.includes('<table')) score += 0.15
    if (email.html && email.html.includes('style=')) score += 0.1
    if (analysis.confidence > 0.7) score += 0.05
    
    return Math.min(score, 1.0)
  }

  private getEnhancedFeatures(analysis: PromptAnalysis): string[] {
    return ['smart-generation', 'intent-analysis', 'html-validation', 'email-optimization']
  }
}

export default new EnhancedAIService()